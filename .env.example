DOCLET_DOCUMENT_ADDR=":8085"
DOCLET_COLLAB_ADDR=":8090"
DOCLET_DATABASE_URL="postgres://doclet:doclet@localhost:5432/doclet?sslmode=disable"
DOCLET_NATS_URL="nats://localhost:4222"

# OpenTelemetry tracing.
# Leave disabled locally unless you have a collector running.
DOCLET_OTEL_ENABLED="false"
DOCLET_OTEL_EXPORTER_ENDPOINT=""
DOCLET_OTEL_EXPORTER_INSECURE="true"
DOCLET_OTEL_EXPORTER_HEADERS=""
DOCLET_OTEL_EXPORT_TIMEOUT="10000"
DOCLET_OTEL_SAMPLER_RATIO="1.0"
DOCLET_OTEL_ENVIRONMENT="local"
DOCLET_OTEL_SERVICE_VERSION="dev"
DOCLET_DOCUMENT_OTEL_SERVICE_NAME="doclet-document"
DOCLET_COLLAB_OTEL_SERVICE_NAME="doclet-collab"

VITE_DOC_SERVICE_URL="http://localhost:8085"
VITE_COLLAB_WS_URL="ws://localhost:8090/ws"
